{%- set lang = lang or "pt" -%}
{%- set t = i18n[lang] -%}
{%- set isEn = lang == "en" -%}
{%- set homeUrl = "/en/" if isEn else "/" -%}
{%- set searchUrl = "/en/search/" if isEn else "/search/" -%}
{%- set groups = collections.notasByCategoryEn if isEn else collections.notasByCategoryPt -%}
<!doctype html>
<html lang="{{ t.htmlLang }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title or "Codex Gigas" }}</title>
    <meta name="description" content="{{ description or 'Jardim digital em Markdown.' }}" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/assets/style.css" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="{{ homeUrl }}">{{ t.tagline }}</a>
      <div class="header-actions">
        <a class="search-link" href="{{ searchUrl }}">{{ t.searchLink }}</a>
        {%- if altUrl %}
        <a class="lang-toggle" href="{{ altUrl }}" title="{{ t.switchTo }}" hreflang="{{ altLang }}">
          {{ altLang | upper }}
        </a>
        {%- endif %}
      </div>
    </header>

    <div class="layout">
      <!-- Navegação (esquerda) -->
      <aside class="sidebar">
        <details class="nav-toggle" open>
          <summary>{{ t.navLabel }}</summary>
        <nav>
          <p class="nav-group">{{ t.navGeneral }}</p>
          <ul>
            <li><a href="{{ homeUrl }}" {% if page.url == homeUrl %}class="active"{% endif %}>{{ t.navHome }}</a></li>
            <li><a href="{{ searchUrl }}" {% if page.url == searchUrl %}class="active"{% endif %}>{{ t.navSearch }}</a></li>
          </ul>
          {%- for group in groups %}
          <p class="nav-group">{{ t.categories[group.category] or group.category }}</p>
          <ul>
            {%- for nota in group.notes %}
            <li>
              <a href="{{ nota.url }}" {% if nota.url == page.url %}class="active"{% endif %}>
                {{ nota.data.title }}
              </a>
            </li>
            {%- endfor %}
          </ul>
          {%- endfor %}
        </nav>
      </aside>

      <!-- Conteúdo (centro) -->
      <main>
        <article class="note">
          <h1>{{ title }}</h1>
          {{ content | safe }}
        </article>

        {%- set incoming = backlinks[lang][conceptSlug] -%}
        {%- if incoming and incoming.length > 0 %}
        <aside class="backlinks">
          <h2>{{ t.backlinks }}</h2>
          <ul>
            {%- for link in incoming %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor %}
          </ul>
        </aside>
        {%- endif %}

        <footer class="site-footer">
          <p>{{ t.footer }}</p>
        </footer>
      </main>

      <!-- Índice da página / TOC (direita) -->
      <aside class="toc" id="toc" hidden>
        <p class="nav-group">{{ t.toc }}</p>
        <ul id="toc-list"></ul>
      </aside>
    </div>

    <script>
      // Gera o índice (TOC) a partir dos h2/h3 do conteúdo.
      (function () {
        const article = document.querySelector(".note");
        const toc = document.getElementById("toc");
        const list = document.getElementById("toc-list");
        if (!article || !toc || !list) return;
        const headings = article.querySelectorAll("h2, h3");
        if (headings.length < 2) return;

        headings.forEach((h, i) => {
          if (!h.id) {
            h.id =
              h.textContent
                .toLowerCase()
                .trim()
                .replace(/[^a-z0-9]+/g, "-")
                .replace(/^-+|-+$/g, "") || "sec-" + i;
          }
          const li = document.createElement("li");
          li.className = h.tagName === "H3" ? "toc-sub" : "";
          const a = document.createElement("a");
          a.href = "#" + h.id;
          a.textContent = h.textContent;
          li.appendChild(a);
          list.appendChild(li);
        });
        toc.hidden = false;
      })();
    </script>
  </body>
</html>
